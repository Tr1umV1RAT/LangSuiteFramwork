import json
import sqlite3
from dataclasses import dataclass

@dataclass
class _SQLiteStoreItem:
    namespace: tuple[Any, ...]
    key: str
    value: Any


class SQLiteRuntimeStore:
    def __init__(self, path: str):
        self.path = path
        self._ensure_schema()

    def _connect(self):
        return sqlite3.connect(self.path, check_same_thread=False)

    def _ensure_schema(self):
        with self._connect() as conn:
            conn.execute(
                "CREATE TABLE IF NOT EXISTS store_items (namespace TEXT NOT NULL, item_key TEXT NOT NULL, value_json TEXT NOT NULL, updated_at REAL NOT NULL DEFAULT (strftime('%%s','now')), PRIMARY KEY(namespace, item_key))"
            )

    def get(self, namespace, key):
        ns = json.dumps(list(namespace) if isinstance(namespace, tuple) else namespace)
        with self._connect() as conn:
            row = conn.execute("SELECT value_json FROM store_items WHERE namespace = ? AND item_key = ?", (ns, key)).fetchone()
        if not row:
            return None
        return _SQLiteStoreItem(tuple(json.loads(ns)), key, json.loads(row[0]))

    async def aget(self, namespace, key):
        return self.get(namespace, key)

    def put(self, namespace, key, value):
        ns_list = list(namespace) if isinstance(namespace, tuple) else namespace
        ns = json.dumps(ns_list)
        value_json = json.dumps(value)
        with self._connect() as conn:
            conn.execute("INSERT OR REPLACE INTO store_items (namespace, item_key, value_json, updated_at) VALUES (?, ?, ?, strftime('%%s','now'))", (ns, key, value_json))

    async def aput(self, namespace, key, value):
        self.put(namespace, key, value)

    def search(self, namespace, query: str = '', limit: int = 5):
        ns_list = list(namespace) if isinstance(namespace, tuple) else namespace
        ns = json.dumps(ns_list)
        query_text = (query or '').lower()
        with self._connect() as conn:
            rows = conn.execute("SELECT item_key, value_json FROM store_items WHERE namespace = ? ORDER BY updated_at DESC", (ns,)).fetchall()
        items = []
        for item_key, value_json in rows:
            value = json.loads(value_json)
            haystack = json.dumps(value).lower()
            if query_text and query_text not in haystack and query_text not in str(item_key).lower():
                continue
            items.append(_SQLiteStoreItem(tuple(ns_list) if isinstance(ns_list, list) else tuple(namespace), item_key, value))
            if len(items) >= limit:
                break
        return items

    async def asearch(self, namespace, query: str = '', limit: int = 5):
        return self.search(namespace, query=query, limit=limit)

    def delete(self, namespace, key):
        ns = json.dumps(list(namespace) if isinstance(namespace, tuple) else namespace)
        with self._connect() as conn:
            conn.execute("DELETE FROM store_items WHERE namespace = ? AND item_key = ?", (ns, key))

    async def adelete(self, namespace, key):
        self.delete(namespace, key)


