def {{ node.id }}_router(state: AgentState):
    messages = state.get("messages", [])
    if messages:
        last_message = messages[-1]
        # Utilisation de getattr pour éviter les crashs avec HumanMessage
        if getattr(last_message, "tool_calls", None):
            return "continue"
    return "end"

