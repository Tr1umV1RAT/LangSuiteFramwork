def build_graph_{{ comp.function_name }}():
    builder = StateGraph(AgentState, context_schema=GraphRuntimeContext)

    {% for node in comp.graph_nodes %}
    {% if node.type not in marker_types %}
    {% set command_targets = comp.edges | selectattr('source', 'equalto', node.id) | selectattr('type', 'equalto', 'direct') | map(attribute='target') | list %}
    {% if node.type in ('command_node', 'handoff_node') and command_targets %}
    builder.add_node("{{ node.id }}", {{ node.id }}_node, ends={{ command_targets | tojson }})
    {% else %}
    builder.add_node("{{ node.id }}", {{ node.id }}_node)
    {% endif %}
    {% endif %}
    {% endfor %}

    {% if comp.needs_tool_node %}
    builder.add_node("tools_execution", ToolNode(ACTIVE_TOOLS))

    {# Câblage automatique LLM <-> Tools #}
    {% for node in comp.graph_nodes %}
    {% if node.type in ('llm_chat', 'react_agent') and node.params.tools_linked %}

    {# On cherche le noeud visuel branché APRÈS le LLM (ex: le Human Interrupt) #}
    {% set next_edges = comp.edges | selectattr("source", "equalto", node.id) | list %}
    {% set next_target = next_edges[0].target if next_edges else 'END' %}

    builder.add_conditional_edges(
        "{{ node.id }}",
        {{ node.id }}_router,
        {"continue": "tools_execution", "end": {% if next_target == 'END' %}END{% else %}"{{ next_target }}"{% endif %}}
    )
    # Retour automatique des tools vers le LLM
    builder.add_edge("tools_execution", "{{ node.id }}")
    {% endif %}
    {% endfor %}
    {% endif %}

    {% set router_id_set = comp.nodes | selectattr('type', 'equalto', 'logic_router') | map(attribute='id') | list %}
    {% for e in comp.edges %}
    {% if e.type == 'direct' %}
    {% set src_node = comp.graph_nodes | selectattr("id", "equalto", e.source) | first | default(None) %}
    {% if src_node and src_node.type in ('llm_chat', 'react_agent') and src_node.params.tools_linked %}
    # Lien direct ignoré car le LLM possède des outils (géré par le routeur conditionnel plus haut)
    {% elif src_node and src_node.type == 'send_fanout' %}
    # Lien direct ignoré ici : send_fanout utilise add_conditional_edges + Send API plus bas
    {% else %}
    builder.add_edge("{{ e.source }}", "{{ e.target }}")
    {% endif %}
    {% endif %}
    {% endfor %}

    {% set conditional_routers = {} %}
    {% for edge in comp.edges %}
    {% if edge.type == 'conditional' and edge.router_id %}
    {% if edge.router_id not in conditional_routers %}
    {% set _ = conditional_routers.update({edge.router_id: []}) %}
    {% endif %}
    {% set _ = conditional_routers[edge.router_id].append(edge) %}
    {% endif %}
    {% endfor %}

    {% for router_id, cond_edges in conditional_routers.items() %}
    {% set incoming_edges = comp.edges | selectattr('target', 'equalto', router_id) | selectattr('type', 'equalto', 'direct') | list %}
    {% set source_of_router = incoming_edges[0].source if incoming_edges else router_id %}
    builder.add_conditional_edges(
        "{{ source_of_router }}",
        {{ router_id }}_route,
        {
            {% for ce in cond_edges %}
            "{{ ce.condition }}": "{{ ce.target }}",
            {% endfor %}
        }
    )
    {% endfor %}


    {% for node in comp.graph_nodes %}
    {% if node.type == 'send_fanout' and node.params.send_target %}
    builder.add_conditional_edges(
        "{{ node.id }}",
        {{ node.id }}_dispatch,
        ["{{ node.params.send_target }}"]
    )
    {% endif %}
    {% endfor %}

    {% if comp.entry_node_id %}
    builder.add_edge(START, "{{ comp.entry_node_id }}")
    {% endif %}

    compile_kwargs = {}
    {% if use_checkpoint %}
    {% if checkpoint_type == 'sqlite' %}
    {% if is_async %}
    compile_kwargs["checkpointer"] = AsyncSqliteSaver.from_conn_string("checkpoints.db")
    {% else %}
    compile_kwargs["checkpointer"] = SqliteSaver(sqlite3.connect("checkpoints.db", check_same_thread=False))
    {% endif %}
    {% else %}
    compile_kwargs["checkpointer"] = MemorySaver()
    {% endif %}
    {% endif %}
    {% if has_memory %}
    compile_kwargs["store"] = store
    {% endif %}
    {% if comp.interrupt_before %}
    compile_kwargs["interrupt_before"] = {{ comp.interrupt_before }}
    {% endif %}

    return builder.compile(**compile_kwargs)

{% endfor %}

{% if not components %}
def _empty_graph_passthrough(state: AgentState):
    return state


def build_graph_main():
    builder = StateGraph(AgentState, context_schema=GraphRuntimeContext)
    builder.add_node("__empty_passthrough__", _empty_graph_passthrough)
    builder.add_edge(START, "__empty_passthrough__")
    builder.add_edge("__empty_passthrough__", END)

    compile_kwargs = {}
    {% if use_checkpoint %}
    {% if checkpoint_type == 'sqlite' %}
    {% if is_async %}
    compile_kwargs["checkpointer"] = AsyncSqliteSaver.from_conn_string("checkpoints.db")
    {% else %}
    compile_kwargs["checkpointer"] = SqliteSaver(sqlite3.connect("checkpoints.db", check_same_thread=False))
    {% endif %}
    {% else %}
    compile_kwargs["checkpointer"] = MemorySaver()
    {% endif %}
    {% endif %}
    {% if has_memory %}
    compile_kwargs["store"] = store
    {% endif %}

    return builder.compile(**compile_kwargs)


