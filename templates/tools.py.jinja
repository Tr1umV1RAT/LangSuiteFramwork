        return 'Filesystem grep pattern is empty.'
    include_hidden = _coerce_bool({{ 'True' if t.params.include_hidden and t.params.include_hidden != 'false' else 'False' }}, default=False)
    case_sensitive = _coerce_bool({{ 'True' if t.params.case_sensitive and t.params.case_sensitive != 'false' else 'False' }}, default=False)
    max_matches = int({{ t.params.max_matches | default(200, true) }})
