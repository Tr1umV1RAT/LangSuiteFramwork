{% else %}
def {{ t.id }}(relative_path: str = "") -> str:
{% endif %}
    """{{ t.description | default("Read-only local filesystem listing from a bounded root path.", true) }}"""
    root, target, target_error = _resolve_filesystem_target({{ t.params.root_path | default('.', true) | tojson }}, relative_path, allow_directory=True)
    if target_error:
        return f"Filesystem list blocked: {target_error}"
    if target is None:
        return "Filesystem list blocked: unable to resolve target directory."
    if not target.is_dir():
        return "Filesystem list blocked: target path is not a directory."
    include_hidden = _coerce_bool({{ 'True' if t.params.include_hidden and t.params.include_hidden != 'false' else 'False' }}, default=False)
    max_results = int({{ t.params.max_results | default(100, true) }})
    rows = []
    for child in sorted(target.iterdir(), key=lambda item: (not item.is_dir(), item.name.lower())):
        try:
            rel = child.resolve().relative_to(root)
        except Exception:
            continue
        if not include_hidden and _is_hidden_relative(rel):
            continue
        entry = {
            'path': str(rel).replace('\\', '/'),
            'name': child.name,
            'kind': 'directory' if child.is_dir() else 'file',
        }
        if child.is_file():
            try:
                entry['size_bytes'] = child.stat().st_size
            except Exception:
                pass
        rows.append(entry)
        if len(rows) >= max_results:
            break
    current_rel = '.' if target == root else str(target.relative_to(root)).replace('\\', '/')
    return json.dumps({'toolkit': 'filesystem', 'operation': 'list_dir', 'root': str(root), 'path': current_rel, 'entries': rows, 'count': len(rows)}, ensure_ascii=False, default=str)

