def _parse_json_object_arg(value: str | None, *, label: str, default=None) -> tuple[dict, str | None]:
    if value is None:
        return (default or {}), None
    raw = str(value).strip()
    if not raw:
        return (default or {}), None
    try:
        parsed = json.loads(raw)
    except Exception as exc:
        return {}, f"{label} must be valid JSON: {exc}"
    if not isinstance(parsed, dict):
        return {}, f"{label} must decode to a JSON object."
    return parsed, None


def _normalize_timeout(value, default: int = 10) -> int:
    try:
        parsed = int(value)
    except Exception:
        return default
    if parsed <= 0:
        return default
    return min(parsed, 120)


def _resolve_requests_target(base_url: str | None, path_or_url: str, *, allow_full_urls: bool) -> tuple[str | None, str | None]:
    raw_target = str(path_or_url or '').strip()
    if not raw_target:
        return None, 'HTTP target is required.'
    parsed = urlparse(raw_target)
    if parsed.scheme and parsed.netloc:
        if allow_full_urls:
            return raw_target, None
        return None, 'Full URLs are blocked for this Requests surface; provide a relative path or enable allow_full_urls.'
    base = str(base_url or '').strip()
    if not base:
        return None, 'Requests surface needs a base_url when full URLs are not allowed.'
    if not urlparse(base).scheme:
        return None, 'Requests base_url must include http:// or https://.'
    return urljoin(base.rstrip('/') + '/', raw_target.lstrip('/')), None


def _requests_preview_payload(response) -> dict:
    try:
        body = response.json()
    except Exception:
        body = response.text
    preview, truncated = _truncate_text(body, max_chars=3000)
    return {
        'status_code': getattr(response, 'status_code', None),
        'content_type': response.headers.get('Content-Type', ''),
        'body_preview': preview,
        'truncated': truncated,
    }


def _extract_brave_web_results(payload) -> list[dict]:
    if not isinstance(payload, dict):
        return []
    web_section = payload.get('web') if isinstance(payload.get('web'), dict) else {}
    rows = web_section.get('results') if isinstance(web_section, dict) else []
    normalized = []
    for row in rows or []:
        if not isinstance(row, dict):
            continue
        normalized.append({
            'title': row.get('title'),
            'url': row.get('url') or row.get('profile', {}).get('url') if isinstance(row.get('profile'), dict) else row.get('url'),
            'snippet': row.get('description') or row.get('extra_snippets') or row.get('meta_description'),
        })
    return normalized

