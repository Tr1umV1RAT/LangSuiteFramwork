def _normalize_provider(provider: str) -> str:
    raw = (provider or '').strip().lower()
    return PROVIDER_ALIASES.get(raw, raw)


def _ensure_provider_configuration(provider: str, explicit_env: str | None = None) -> None:
    provider = _normalize_provider(provider)
    env_name = (explicit_env or '').strip() or PROVIDER_ENV_VARS.get(provider)
    if not env_name:
        return
    if os.getenv(env_name):
        return
    raise RuntimeError(f"[provider_config_missing] Provider '{provider}' requires environment variable '{env_name}' for runtime execution")


def _build_chat_model(*, provider: str, model_name: str, temperature: float, explicit_env: str | None = None, api_base_url: str | None = None, max_tokens: int | None = None, top_p: float | None = None, frequency_penalty: float | None = None, presence_penalty: float | None = None, stop_sequences: list[str] | None = None):
    provider = _normalize_provider(provider)
    api_base_url = (api_base_url or '').strip() or None
    if provider in OPENAI_COMPAT_PROVIDER_FAMILIES:
        if not api_base_url:
            raise RuntimeError(f"[provider_config_missing] Provider '{provider}' requires api_base_url for runtime execution")
        from langchain_openai import ChatOpenAI
        api_key = (os.getenv((explicit_env or '').strip()) if (explicit_env or '').strip() else None) or os.getenv('OPENAI_API_KEY') or 'not-needed'
        kwargs = {
            'model': model_name,
            'temperature': temperature,
            'base_url': api_base_url,
            'api_key': api_key,
        }
        if max_tokens is not None:
            kwargs['max_tokens'] = max_tokens
        if top_p is not None:
            kwargs['top_p'] = top_p
        if frequency_penalty is not None:
            kwargs['frequency_penalty'] = frequency_penalty
        if presence_penalty is not None:
            kwargs['presence_penalty'] = presence_penalty
        if stop_sequences:
            kwargs['stop'] = stop_sequences
        return ChatOpenAI(**kwargs)
    _ensure_provider_configuration(provider, explicit_env)
    from langchain.chat_models import init_chat_model
    llm = init_chat_model(model=model_name, model_provider=provider, temperature=temperature)
    extra_kwargs = {}
    if max_tokens is not None:
        extra_kwargs['max_tokens'] = max_tokens
    if top_p is not None:
        extra_kwargs['top_p'] = top_p
    if frequency_penalty is not None:
        extra_kwargs['frequency_penalty'] = frequency_penalty
    if presence_penalty is not None:
        extra_kwargs['presence_penalty'] = presence_penalty
    if stop_sequences:
        extra_kwargs['stop'] = stop_sequences
    if extra_kwargs and hasattr(llm, 'bind'):
        llm = llm.bind(**extra_kwargs)
    return llm


def _find_subagent_group(group_name: str | None):
    wanted_group = (group_name or '').strip() or 'default'
    for group in SUBAGENT_LIBRARY:
        if not isinstance(group, dict):
            continue
        group_label = str(group.get('name') or '').strip() or 'default'
        if group_label == wanted_group:
            return {'group': group_label, 'agents': group.get('agents', []) or []}
    return None


def _find_subagent_entry(group_name: str | None, agent_name: str | None):
    if not agent_name:
        return None
    resolved_group = _find_subagent_group(group_name)
    if not resolved_group:
        return None
    wanted_agent = (agent_name or '').strip()
    for agent in resolved_group.get('agents', []) or []:
        if not isinstance(agent, dict):
            continue
        if str(agent.get('name') or '').strip() == wanted_agent:
            return {'group': resolved_group['group'], 'agent': agent}
    return None


def _resolve_subagent_tools(agent_entry):
    tool_ids = []
    if isinstance(agent_entry, dict):
        tool_ids = agent_entry.get('tools', []) or []
    return [ACTIVE_TOOLS_BY_ID[tool_id] for tool_id in tool_ids if tool_id in ACTIVE_TOOLS_BY_ID]


def _invoke_subagent(agent_entry, prompt_text: str, *, provider: str, model_name: str, temperature: float, explicit_env: str | None = None, api_base_url: str | None = None, max_tokens: int | None = None, top_p: float | None = None, frequency_penalty: float | None = None, presence_penalty: float | None = None, stop_sequences: list[str] | None = None):
    from langchain_core.messages import SystemMessage, HumanMessage
    subagent_tools = _resolve_subagent_tools(agent_entry)
    llm = _build_chat_model(provider=provider, model_name=model_name, temperature=temperature, explicit_env=explicit_env, api_base_url=api_base_url, max_tokens=max_tokens, top_p=top_p, frequency_penalty=frequency_penalty, presence_penalty=presence_penalty, stop_sequences=stop_sequences)
    llm_with_tools = llm.bind_tools(subagent_tools) if subagent_tools else llm
    msgs = [
        SystemMessage(content=str(agent_entry.get('systemPrompt') or 'Tu es un sous-agent expert invoqué comme outil.')),
        HumanMessage(content=prompt_text),
    ]
    return llm_with_tools, msgs


def _format_subagent_group_listing(group_name: str | None):
    resolved_group = _find_subagent_group(group_name)
    if not resolved_group:
        return []
    rows = []
    for agent in resolved_group.get('agents', []) or []:
        if not isinstance(agent, dict):
            continue
        rows.append({
            'name': str(agent.get('name') or '').strip(),
            'description': str(agent.get('description') or '').strip(),
        })
    return [row for row in rows if row['name']]


def _subagent_hint_text(tool_name: str, group_name: str | None, target_agent: str | None, *, max_invocations: int, allow_repeat: bool):
    if target_agent:
        return f"Tool '{tool_name}' delegates to subagent '{target_agent}' in group '{group_name or 'default'}'. Use it when this specialist is needed. The subagent runs ephemerally with its configured system prompt and tools. Max invocations: {max_invocations}. Repeats allowed: {allow_repeat}."
    listing = _format_subagent_group_listing(group_name)
    available = ', '.join(f"{row['name']} ({row['description'] or 'no description'})" for row in listing) or 'none'
    return f"Tool '{tool_name}' dispatches to subagents from group '{group_name or 'default'}'. Call it with agent_name and description. Available agents: {available}. The selected subagent runs ephemerally with its configured system prompt and tools. Max invocations: {max_invocations}. Repeats allowed: {allow_repeat}."


