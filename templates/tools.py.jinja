        return _tool_payload_json('shell', 'shell_command', 'blocked', reason_code='shell_not_armed', message=message, requested_command=str(command or ''), root=configured_root, allowed_commands=allowed_commands)
    root, root_error = _resolve_filesystem_root(configured_root)
    if root_error:
        return _tool_payload_json('shell', 'shell_command', 'blocked', reason_code='invalid_cwd', message=root_error, requested_command=str(command or ''), root=str(root) if root is not None else configured_root, allowed_commands=allowed_commands)
    if not allowed_commands:
        message = 'allowed_commands is empty for this shell tool.'
        return _tool_payload_json('shell', 'shell_command', 'blocked', reason_code='missing_shell_allowlist', message=message, requested_command=str(command or ''), root=str(root), allowed_commands=allowed_commands)
    argv, command_error = _normalize_shell_command(command)
    if command_error or argv is None:
