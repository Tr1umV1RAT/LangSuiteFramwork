    executable = Path(argv[0]).name.lower()
    if executable not in allowed_commands:
        message = f"Executable '{executable}' is not in the allowlist ({', '.join(allowed_commands)})."
        return _tool_payload_json('shell', 'shell_command', 'blocked', reason_code='shell_command_not_allowed', message=message, requested_command=str(command or ''), parsed_command=argv, root=str(root), allowed_commands=allowed_commands)
    try:
        completed = subprocess.run(argv, cwd=str(root), env=_build_shell_env(), capture_output=True, text=True, timeout=timeout_seconds, shell=False)
    except Exception as exc:
        return _tool_payload_json('shell', 'shell_command', 'failed', reason_code='shell_runtime_failure', message=str(exc), requested_command=str(command or ''), parsed_command=argv, root=str(root), allowed_commands=allowed_commands)
    stdout, stdout_truncated = _truncate_text(completed.stdout or '', max_chars=6000)
    stderr, stderr_truncated = _truncate_text(completed.stderr or '', max_chars=6000)
    status = 'succeeded' if completed.returncode == 0 else 'failed'
    reason_code = None if completed.returncode == 0 else 'shell_command_failed'
    message = 'Shell command completed successfully.' if completed.returncode == 0 else f'Shell command exited with status {completed.returncode}.'
    return _tool_payload_json('shell', 'shell_command', status, reason_code=reason_code, message=message, root=str(root), requested_command=str(command or ''), parsed_command=argv, allowed_commands=allowed_commands, exit_code=completed.returncode, stdout=stdout, stderr=stderr, stdout_truncated=stdout_truncated, stderr_truncated=stderr_truncated)

