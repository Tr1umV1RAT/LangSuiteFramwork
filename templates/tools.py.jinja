        if truncated and payload.get('warning') is None:
            payload['warning'] = 'Result preview truncated; tighten the query or add LIMIT for a smaller payload.'
            text_result, _ = _truncate_text(payload)
        return text_result
    except Exception as e:
        return f"SQL error: {str(e)}"

