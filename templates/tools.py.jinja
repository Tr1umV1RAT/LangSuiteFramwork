{% elif t.type == 'rpg_dice_roller' %}
{% elif t.type == 'rpg_dice_roller' %}
@tool
def {{ t.id }}(notation: str) -> str:
    """{{ t.description | default("Simule un jet de dés pour un jeu de rôle. Notation standard RPG : 1d20, 2d6, 3d8+2.", true) }}"""
    import re
    import random
    
    match = re.match(r'(\d+)\s*[dD]\s*(\d+)(?:\s*([\+\-])\s*(\d+))?', notation.strip())
    if not match:
        return f"Erreur : '{notation}' est invalide. Utilisez le format '1d20' ou '2d6+3'."
        
    num_dice = int(match.group(1))
    faces = int(match.group(2))
    sign = match.group(3)
    modifier = int(match.group(4)) if match.group(4) else 0
    
    if num_dice > 100 or faces > 1000:
        return "Erreur : Nombre de dés ou de faces trop élevé."
        
    rolls = [random.randint(1, faces) for _ in range(num_dice)]
    total = sum(rolls)
    
    if sign == '+':
        total += modifier
    elif sign == '-':
        total -= modifier
        
    details = f"{rolls} {'+ ' + str(modifier) if sign == '+' else '- ' + str(modifier) if sign == '-' else ''}"
    return f"Jet de {notation} : {details.strip()} => TOTAL : {total}"

