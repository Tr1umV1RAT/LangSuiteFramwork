        return f"SQL execution blocked: read_only=false is not allowed in this build."
    if not allowed:
        return f"SQL execution blocked: {reason}"
    db = SQLDatabase.from_uri(db_uri)
    try:
        result = db.run(query)
        warning = _sql_limit_warning(query)
        payload = {'mode': 'read_only', 'db_path': db_path, 'query': query, 'result': result, 'warning': warning}
