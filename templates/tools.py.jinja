{% elif t.type == 'pw_get_elements' %}
@tool
{% if is_async %}
async def {{ t.id }}(selector: str) -> str:
{% else %}
def {{ t.id }}(selector: str) -> str:
{% endif %}
    """{{ t.description | default("Récupère les éléments correspondant au sélecteur CSS. Utile pour découvrir la structure de la page.", true) }}"""
    try:
        {% if is_async %}
        page = await get_playwright_page()
        {% else %}
        page = get_playwright_page()
        {% endif %}
        if page is None:
            return "Erreur : Playwright non disponible."
        {% if is_async %}
        elements = await page.evaluate("""(sel) => {
        {% else %}
        elements = page.evaluate("""(sel) => {
        {% endif %}
            return Array.from(document.querySelectorAll(sel)).slice(0, 20).map(el => ({
                tag: el.tagName.toLowerCase(),
                id: el.id || null,
                class: el.className || null,
                text: el.innerText ? el.innerText.trim().substring(0, 80) : null,
                type: el.type || null,
                name: el.name || null,
                href: el.href || null
            }));
        }""", selector)
        if not elements:
            return f"Aucun élément trouvé pour le sélecteur '{selector}'."
        lines = []
        for el in elements:
            parts = [f"<{el['tag']}"]
            if el.get('id'): parts.append(f'id="{el["id"]}"')
            if el.get('class'): parts.append(f'class="{el["class"]}"')
            if el.get('name'): parts.append(f'name="{el["name"]}"')
            if el.get('type'): parts.append(f'type="{el["type"]}"')
            parts.append(">")
            desc = " ".join(parts)
            if el.get('text'): desc += f' → "{el["text"]}"'
            lines.append(f"  {desc}")
        return f"Éléments trouvés ({len(elements)}) :\n" + "\n".join(lines)
    except Exception as e:
        return f"Erreur récupération éléments pour '{selector}'. Détail : {str(e)}"

