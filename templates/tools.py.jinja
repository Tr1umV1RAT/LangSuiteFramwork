    try:
        regex = re.compile(wanted_pattern, 0 if case_sensitive else re.IGNORECASE)
    except Exception as exc:
        return f"Filesystem grep blocked: invalid regex pattern ({exc})."
    matches = []
    try:
        for candidate, relative in _iter_filesystem_matches(root, file_glob, include_hidden=include_hidden):
            if not candidate.is_file():
                continue
            try:
