{% endif %}
    """{{ t.description | default("Run a read-only SQL query against the configured SQLite database.", true) }}"""
    import json
    from langchain_community.utilities import SQLDatabase

    db_uri, db_path = _normalize_sqlite_target({{ t.params.db_path | default('data.db', true) | tojson }})
    read_only = _coerce_bool({{ 'True' if t.params.read_only is not sameas false and t.params.read_only != 'false' else 'False' }}, default=True)
    allowed, reason = _sql_read_only_guard(query)
