def _normalize_sqlite_target(db_path: str | None) -> tuple[str, str]:
    raw_value = str(db_path or 'data.db').strip() or 'data.db'
    if raw_value.startswith('sqlite:///'):
        return raw_value, raw_value[len('sqlite:///'):]
    return f"sqlite:///{raw_value}", raw_value


def _sql_read_only_guard(query: str) -> tuple[bool, str]:
    stripped = (query or '').strip()
    if not stripped:
        return False, 'SQL query is empty.'
    normalized = stripped.lower()
    if ';' in stripped.rstrip(';'):
        return False, 'Read-only mode rejects multiple SQL statements.'
    allowed_prefixes = ('select', 'with', 'pragma', 'explain')
    if not normalized.startswith(allowed_prefixes):
        return False, 'Read-only mode only allows SELECT / WITH / PRAGMA / EXPLAIN queries in this pass.'
    blocked_tokens = ('insert ', 'update ', 'delete ', 'drop ', 'alter ', 'create ', 'replace ', 'truncate ', 'attach ', 'detach ', 'vacuum', 'reindex ')
    if any(token in normalized for token in blocked_tokens):
        return False, 'Read-only mode blocked a mutating or unsafe SQL statement.'
    return True, 'Query accepted by the read-only guard.'


def _coerce_bool(value, default: bool = False) -> bool:
    if isinstance(value, bool):
        return value
    if value is None:
        return default
    if isinstance(value, (int, float)):
        return bool(value)
    normalized = str(value).strip().lower()
    if normalized in {'true', '1', 'yes', 'y', 'on'}:
        return True
    if normalized in {'false', '0', 'no', 'n', 'off'}:
        return False
    return default


def _truncate_text(value, max_chars: int = 4000) -> tuple[str, bool]:
    text = value if isinstance(value, str) else json.dumps(value, ensure_ascii=False, default=str)
    if len(text) <= max_chars:
        return text, False
    return text[:max_chars] + "\n... (truncated)", True


def _sql_limit_warning(query: str) -> str | None:
    normalized = (query or '').strip().lower()
    if not normalized:
        return None
    if normalized.startswith(('select', 'with')) and ' limit ' not in normalized and not normalized.endswith(' limit'):
        return 'Consider adding LIMIT for more compact, predictable previews.'
    return None


def _normalize_positive_int(value: str, *, label: str) -> tuple[int | None, str | None]:
    raw = str(value or '').strip()
    if not raw:
        return None, f'{label} is required.'
    try:
        parsed = int(raw)
    except Exception:
        return None, f'{label} must be an integer.'
    if parsed <= 0:
        return None, f'{label} must be a positive integer.'
    return parsed, None


def _resolve_filesystem_root(root_path: str | None) -> tuple[Path | None, str | None]:
    raw = str(root_path or '.').strip() or '.'
    try:
        resolved = Path(raw).expanduser().resolve()
    except Exception as exc:
        return None, f"Invalid filesystem root '{raw}': {exc}"
    if not resolved.exists():
        return None, f"Filesystem root does not exist: {resolved}"
    if not resolved.is_dir():
        return None, f"Filesystem root is not a directory: {resolved}"
    return resolved, None


def _is_hidden_relative(path: Path) -> bool:
    return any(part.startswith('.') for part in path.parts if part not in ('', '.'))


def _resolve_filesystem_target(root_path: str | None, relative_path: str, *, allow_directory: bool) -> tuple[Path | None, Path | None, str | None]:
    root, root_error = _resolve_filesystem_root(root_path)
    if root_error or root is None:
        return None, None, root_error
    raw = str(relative_path or '').strip()
    if not raw:
        target = root
    else:
        normalized = raw.replace('\\', '/')
        if normalized.startswith('/'):
            return root, None, 'Filesystem path must be relative to the configured root, not absolute.'
        pieces = [piece for piece in normalized.split('/') if piece not in ('', '.')]
        if any(piece == '..' for piece in pieces):
            return root, None, 'Filesystem path must stay inside the configured root.'
        target = (root.joinpath(*pieces)).resolve()
    try:
        target.relative_to(root)
    except Exception:
        return root, None, 'Filesystem path resolved outside the configured root.'
    if not target.exists():
        rel = '.' if target == root else str(target)
        return root, None, f'Filesystem path not found: {rel}'
    if not allow_directory and target.is_dir():
        return root, None, 'Expected a file path but got a directory.'
    return root, target, None


def _iter_filesystem_matches(root: Path, pattern: str, *, include_hidden: bool):
    wanted = str(pattern or '').strip() or '**/*'
    if wanted.startswith('/'):
        raise ValueError('Glob pattern must be relative to the configured root.')
    for candidate in root.glob(wanted):
        resolved = candidate.resolve()
        try:
            relative = resolved.relative_to(root)
        except Exception:
            continue
        if not include_hidden and _is_hidden_relative(relative):
            continue
        yield resolved, relative


def _looks_binary(blob: bytes) -> bool:
    if not blob:
        return False
    if b'\x00' in blob:
        return True
    sample = blob[:4096]
    nontext = sum(1 for byte in sample if byte < 9 or (13 < byte < 32))
    return nontext > max(8, len(sample) // 6)


def _read_text_file_preview(path: Path, *, max_bytes: int = 200000) -> tuple[str | None, str | None]:
    try:
        blob = path.read_bytes()
    except Exception as exc:
        return None, f'Failed to read file: {exc}'
    if _looks_binary(blob):
        return None, 'Binary or non-text file preview is not supported by this filesystem pass.'
    preview = blob[:max_bytes]
    try:
        text = preview.decode('utf-8')
    except UnicodeDecodeError:
        text = preview.decode('utf-8', errors='replace')
    if len(blob) > max_bytes:
        text += "\n... (truncated)"
    return text, None


def _read_text_file_for_mutation(path: Path, *, max_bytes: int = 200000) -> tuple[str | None, str | None]:
    try:
        blob = path.read_bytes()
    except Exception as exc:
        return None, f'Failed to read file: {exc}'
    if _looks_binary(blob):
        return None, 'Binary or non-text files are not supported by this text-mutation pass.'
    if len(blob) > max_bytes:
        return None, f'File exceeds the configured max_bytes limit ({len(blob)} > {max_bytes}).'
    try:
        return blob.decode('utf-8'), None
    except UnicodeDecodeError:
        return blob.decode('utf-8', errors='replace'), None


def _resolve_filesystem_target_for_write(root_path: str | None, relative_path: str, *, create_dirs: bool, prepare_dirs: bool = False) -> tuple[Path | None, Path | None, str | None]:
    root, root_error = _resolve_filesystem_root(root_path)
    if root_error or root is None:
        return None, None, root_error
    raw = str(relative_path or '').strip()
    if not raw:
        return root, None, 'Filesystem path is required.'
    normalized = raw.replace('\\', '/')
    if normalized.startswith('/'):
        return root, None, 'Filesystem path must be relative to the configured root, not absolute.'
    pieces = [piece for piece in normalized.split('/') if piece not in ('', '.')]
    if not pieces or any(piece == '..' for piece in pieces):
        return root, None, 'Filesystem path must stay inside the configured root.'
    target = (root.joinpath(*pieces)).resolve()
    try:
        target.relative_to(root)
    except Exception:
        return root, None, 'Filesystem path resolved outside the configured root.'
    if target.parent.exists() and not target.parent.is_dir():
        return root, None, 'Parent path is not a directory under the configured root.'
    if create_dirs and prepare_dirs:
        try:
            target.parent.mkdir(parents=True, exist_ok=True)
        except Exception as exc:
            return root, None, f'Failed to prepare parent directory: {exc}'
    elif not target.parent.exists() and not create_dirs:
        return root, None, 'Parent directory does not exist under the configured root.'
    if target.exists() and target.is_dir():
        return root, None, 'Expected a file path but got a directory.'
    return root, target, None


def _normalize_patch_relative_path(value: str | None) -> tuple[str | None, str | None]:
    raw = str(value or '').strip()
    if not raw:
        return None, 'Patch path is empty.'
    if raw == '/dev/null':
        return '/dev/null', None
    path_token = raw.split('	', 1)[0].strip().split(' ', 1)[0].strip()
    if path_token.startswith('a/') or path_token.startswith('b/'):
        path_token = path_token[2:]
    normalized = path_token.replace('\\', '/')
    if normalized.startswith('/'):
        return None, 'Patch paths must stay relative to the configured root.'
    parts = [part for part in normalized.split('/') if part not in ('', '.')]
    if not parts or any(part == '..' for part in parts):
        return None, 'Patch paths must stay inside the configured root.'
    return '/'.join(parts), None


def _parse_unified_patch(patch_text: str) -> tuple[list[dict] | None, str | None]:
    raw = str(patch_text or '')
    if not raw.strip():
        return None, 'Patch text is empty.'
    lines = raw.splitlines()
    file_patches: list[dict] = []
    current_file = None
    current_hunk = None
    hunk_re = re.compile(r'^@@ -(\d+)(?:,(\d+))? \+(\d+)(?:,(\d+))? @@')

    def _flush_hunk():
        nonlocal current_hunk, current_file
        if current_hunk is not None and current_file is not None:
            current_file.setdefault('hunks', []).append(current_hunk)
            current_hunk = None

    def _flush_file():
        nonlocal current_file
        _flush_hunk()
        if current_file is not None:
            file_patches.append(current_file)
            current_file = None

    for line in lines:
        if line.startswith('diff --git '):
            _flush_file()
            continue
        if line.startswith(('index ', 'new file mode ', 'deleted file mode ', 'similarity index ', 'rename from ', 'rename to ')):
            continue
        if line.startswith('--- '):
            _flush_file()
            old_path, path_error = _normalize_patch_relative_path(line[4:])
            if path_error:
                return None, path_error
            current_file = {'old_path': old_path, 'new_path': None, 'hunks': [], 'no_newline_at_eof': False}
            continue
        if line.startswith('+++ '):
            if current_file is None:
                return None, 'Unified diff is missing the preceding --- line.'
            new_path, path_error = _normalize_patch_relative_path(line[4:])
            if path_error:
                return None, path_error
            current_file['new_path'] = new_path
            continue
        if line.startswith('@@ '):
            if current_file is None or current_file.get('new_path') is None:
                return None, 'Unified diff hunk appeared before ---/+++ headers.'
            _flush_hunk()
            match = hunk_re.match(line)
            if not match:
                return None, f'Invalid unified diff hunk header: {line}'
            current_hunk = {
                'old_start': int(match.group(1)),
                'old_count': int(match.group(2) or '1'),
                'new_start': int(match.group(3)),
                'new_count': int(match.group(4) or '1'),
                'lines': [],
            }
            continue
        if line == '\\ No newline at end of file':
            if current_file is not None:
                current_file['no_newline_at_eof'] = True
            continue
        if current_hunk is None:
            if not line.strip():
                continue
            return None, f'Unexpected line outside a unified diff hunk: {line}'
        if not line:
            current_hunk['lines'].append((' ', ''))
            continue
        marker = line[0]
        if marker not in {' ', '+', '-'}:
            return None, f'Unsupported unified diff line: {line}'
        current_hunk['lines'].append((marker, line[1:]))

    _flush_file()
    if not file_patches:
        return None, 'No unified diff file patches were found.'
    for file_patch in file_patches:
        if file_patch.get('new_path') is None:
            return None, 'Unified diff file patch is missing a +++ target path.'
        if not file_patch.get('hunks'):
            return None, 'Unified diff file patch has no hunks.'
    return file_patches, None


def _apply_unified_patch_to_text(original_text: str, file_patch: dict, *, creating: bool) -> tuple[str | None, str | None]:
    current_lines = str(original_text or '').splitlines()
    had_trailing_newline = bool(original_text) and str(original_text).endswith('\n')
    output_lines: list[str] = []
    cursor = 0
    for hunk in file_patch.get('hunks', []) or []:
        start = max(int(hunk.get('old_start', 1)) - 1, 0)
        if start < cursor or start > len(current_lines):
            return None, f'Patch hunk start {start + 1} is outside the target file.'
        output_lines.extend(current_lines[cursor:start])
        idx = start
        for marker, line_text in hunk.get('lines', []) or []:
            if marker == ' ':
                if idx >= len(current_lines) or current_lines[idx] != line_text:
                    return None, f'Patch context mismatch near line {idx + 1}.'
                output_lines.append(current_lines[idx])
                idx += 1
            elif marker == '-':
                if idx >= len(current_lines) or current_lines[idx] != line_text:
                    return None, f'Patch removal mismatch near line {idx + 1}.'
                idx += 1
            elif marker == '+':
                output_lines.append(line_text)
        cursor = idx
    output_lines.extend(current_lines[cursor:])
    new_text = '\n'.join(output_lines)
    keep_trailing_newline = (creating and bool(output_lines)) or had_trailing_newline
    if file_patch.get('no_newline_at_eof'):
        keep_trailing_newline = False
    if keep_trailing_newline and new_text:
        new_text += '\n'
    return new_text, None


def _summarize_unified_patch(file_patch: dict) -> dict:
    additions = 0
    deletions = 0
    for hunk in file_patch.get('hunks', []) or []:
        for marker, _ in hunk.get('lines', []) or []:
            if marker == '+':
                additions += 1
            elif marker == '-':
                deletions += 1
    return {
        'hunks': len(file_patch.get('hunks', []) or []),
        'additions': additions,
        'deletions': deletions,
    }


def _filesystem_relative_path(root: Path | None, target: Path | None) -> str | None:
    if root is None or target is None:
        return None
    try:
        return str(target.relative_to(root)).replace('\\', '/')
    except Exception:
        return None


def _blocking_reason(reason_code: str, message: str, **extra) -> dict:
    payload = {'reason_code': reason_code, 'message': message}
    payload.update({key: value for key, value in extra.items() if value is not None})
    return payload


def _tool_payload_json(toolkit: str, operation: str, status: str, **payload) -> str:
    envelope = {'toolkit': toolkit, 'operation': operation, 'status': status}
    envelope.update({key: value for key, value in payload.items() if value is not None})
    return json.dumps(envelope, ensure_ascii=False, default=str)


def _normalize_mutation_mode(mode: str | None) -> tuple[str | None, str | None]:
    normalized = str(mode or 'preview').strip().lower() or 'preview'
    if normalized not in {'preview', 'apply'}:
        return None, "Mode must be 'preview' or 'apply'."
    return normalized, None


def _filesystem_reason_code(message: str | None, *, missing_code: str = 'target_missing') -> str:
    normalized = str(message or '').lower()
    if 'outside the configured root' in normalized or 'must stay inside the configured root' in normalized or 'not absolute' in normalized:
        return 'root_escape_attempt'
    if 'not found' in normalized:
        return missing_code
    if 'exceeds max_bytes' in normalized or 'file exceeds the configured max_bytes limit' in normalized:
        return 'file_too_large'
    if 'already exists and overwrite_existing=false' in normalized:
        return 'overwrite_not_allowed'
    if 'already exists for create patch' in normalized:
        return 'target_already_exists'
    if 'file creation is disabled' in normalized:
        return 'patch_creation_not_allowed'
    if 'find_text was not found' in normalized:
        return 'edit_match_missing'
    if 'unified diff' in normalized or 'patch text is empty' in normalized or 'unsupported unified diff line' in normalized or 'unexpected line outside a unified diff hunk' in normalized:
        return 'invalid_patch'
    if 'binary or non-text' in normalized:
        return 'binary_file_not_supported'
    if 'path is required' in normalized or 'expected a file path but got a directory' in normalized or 'filesystem root' in normalized or 'parent directory does not exist' in normalized or 'parent path is not a directory' in normalized:
        return 'invalid_path'
    return 'blocked'


def _build_shell_env() -> dict[str, str]:
    allowed = ('PATH', 'HOME', 'USER', 'USERNAME', 'TMP', 'TEMP', 'SYSTEMROOT', 'COMSPEC', 'PATHEXT', 'WINDIR')
    return {key: os.environ[key] for key in allowed if key in os.environ}


def _normalize_allowed_commands(value) -> list[str]:
    if not isinstance(value, list):
        return []
    rows = []
    for item in value:
        normalized = str(item or '').strip()
        if normalized:
            rows.append(Path(normalized).name.lower())
    return rows


def _normalize_shell_command(command: str) -> tuple[list[str] | None, str | None]:
    raw = str(command or '').strip()
    if not raw:
        return None, 'Shell command is empty.'
    try:
        argv = shlex.split(raw, posix=(os.name != 'nt'))
    except Exception as exc:
        return None, f'Unable to parse shell command: {exc}'
    if not argv:
        return None, 'Shell command is empty.'
    head = str(argv[0] or '').strip()
    if not head:
        return None, 'Shell command executable is empty.'
    if '/' in head or '\\' in head:
        return None, 'Executable must be a bare command name from the allowlist, not a path.'
    argv[0] = Path(head).name
    return argv, None


def _normalize_repo_relative_path(path: str) -> tuple[str | None, str | None]:
    raw = str(path or '').strip()
    if not raw:
        return None, 'GitHub file path is empty.'
    normalized = raw.replace('\\', '/')
    if normalized.startswith('/'):
        return None, 'GitHub file path must be repository-relative, not absolute.'
    parts = [part for part in normalized.split('/') if part not in ('', '.')]
    if not parts or any(part == '..' for part in parts):
        return None, 'GitHub file path must stay inside the configured repository.'
    return '/'.join(parts), None


def _is_valid_github_repository(value: str) -> bool:
    return bool(re.fullmatch(r'[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+', str(value or '').strip()))


