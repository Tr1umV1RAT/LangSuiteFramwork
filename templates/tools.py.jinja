                    continue
            except Exception:
                continue
            text_preview, read_error = _read_text_file_preview(candidate, max_bytes=500000)
            if read_error or text_preview is None:
                continue
            for line_number, line in enumerate(text_preview.splitlines(), start=1):
                if regex.search(line):
                    matches.append({
                        'path': str(relative).replace('\\', '/'),
                        'line_number': line_number,
                        'line': line[:500],
                    })
                    if len(matches) >= max_matches:
                        return json.dumps({'toolkit': 'filesystem', 'operation': 'grep', 'root': str(root), 'pattern': wanted_pattern, 'file_glob': file_glob, 'matches': matches, 'count': len(matches)}, ensure_ascii=False, default=str)
        return json.dumps({'toolkit': 'filesystem', 'operation': 'grep', 'root': str(root), 'pattern': wanted_pattern, 'file_glob': file_glob, 'matches': matches, 'count': len(matches)}, ensure_ascii=False, default=str)
    except Exception as exc:
