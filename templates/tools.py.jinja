    mode, mode_error = _normalize_mutation_mode(mode)
    allow_create = _coerce_bool({{ 'True' if t.params.allow_create and t.params.allow_create != 'false' else 'False' }}, default=False)
    create_dirs = _coerce_bool({{ 'True' if t.params.create_dirs and t.params.create_dirs != 'false' else 'False' }}, default=False)
    max_files = int({{ t.params.max_files | default(8, true) }})
    max_bytes = int({{ t.params.max_bytes | default(200000, true) }})
    configured_root = {{ t.params.root_path | default('.', true) | tojson }}
    resolved_root, root_error = _resolve_filesystem_root(configured_root)
    root_value = str(resolved_root) if resolved_root is not None else None
    if mode_error:
        reason = _blocking_reason('invalid_mode', mode_error, requested_mode=str(requested_mode or ''))
        return _tool_payload_json('filesystem', 'apply_patch', 'blocked', mode='preview', requested_mode=str(requested_mode or ''), reason_code='invalid_mode', message=mode_error, blocking_reasons=[reason], files_to_modify=[], files_to_create=[], files_rejected=[])
    if root_error:
        reason = _blocking_reason('invalid_path', root_error)
        return _tool_payload_json('filesystem', 'apply_patch', 'blocked', mode=mode, root=root_value, reason_code='invalid_path', message=root_error, blocking_reasons=[reason], files_to_modify=[], files_to_create=[], files_rejected=[])
    file_patches, patch_error = _parse_unified_patch(patch)
    if patch_error or file_patches is None:
        message = patch_error or 'Patch text could not be parsed.'
        reason_code = _filesystem_reason_code(message)
        if reason_code == 'blocked':
            reason_code = 'invalid_patch'
        reason = _blocking_reason(reason_code, message)
        return _tool_payload_json('filesystem', 'apply_patch', 'blocked', mode=mode, root=root_value, reason_code=reason_code, message=message, blocking_reasons=[reason], files_to_modify=[], files_to_create=[], files_rejected=[])
    if len(file_patches) > max_files:
        message = f"Patch touches {len(file_patches)} files which exceeds max_files ({max_files})."
        reason = _blocking_reason('too_many_files_in_patch', message)
        return _tool_payload_json('filesystem', 'apply_patch', 'blocked', mode=mode, root=root_value, reason_code='too_many_files_in_patch', message=message, blocking_reasons=[reason], files_touched=len(file_patches), files_to_modify=[], files_to_create=[], files_rejected=[])

    preview_files = []
    files_to_modify = []
    files_to_create = []
    files_rejected = []
    blocking_reasons = []
    prepared_writes = []

    for file_patch in file_patches:
        old_path = file_patch.get('old_path')
        new_path = file_patch.get('new_path')
        target_relative = new_path if new_path != '/dev/null' else old_path
        creating = old_path == '/dev/null'
        action = 'create' if creating else 'modify'
        summary = _summarize_unified_patch(file_patch)
        preview_entry = {
            **summary,
            'old_path': old_path,
            'new_path': new_path,
            'path': target_relative,
            'created': creating,
            'action': action,
        }

        def reject(reason_code: str, message: str):
            reason = _blocking_reason(reason_code, message, path=target_relative)
            entry = dict(preview_entry)
            entry.update({'status': 'rejected', 'reason_code': reason_code, 'message': message})
            preview_files.append(entry)
            files_rejected.append(entry)
            blocking_reasons.append(reason)

        if new_path == '/dev/null':
            reject('patch_delete_not_supported', 'File deletion is not supported by this patch pass.')
            continue
        if old_path not in {None, '/dev/null'} and new_path not in {None, '/dev/null'} and old_path != new_path:
            reject('patch_rename_not_supported', f"Path rename '{old_path}' -> '{new_path}' is not supported by this patch pass.")
            continue
        if not target_relative or target_relative == '/dev/null':
            reject('invalid_patch', 'Target file path is missing from the patch.')
            continue

        if creating:
            if not allow_create:
                reject('patch_creation_not_allowed', f"File creation is disabled for '{target_relative}'.")
                continue
            root, target, target_error = _resolve_filesystem_target_for_write(configured_root, target_relative, create_dirs=create_dirs, prepare_dirs=False)
            if target_error:
                reject(_filesystem_reason_code(target_error), target_error)
                continue
            if target is None or root is None:
                reject('invalid_path', 'Unable to resolve patch target file.')
                continue
            if target.exists():
                reject('target_already_exists', f"Target file already exists for create patch '{target_relative}'.")
                continue
            original_text = ''
        else:
            root, target, target_error = _resolve_filesystem_target(configured_root, target_relative, allow_directory=False)
            if target_error:
                reject(_filesystem_reason_code(target_error, missing_code='target_missing'), target_error)
                continue
            if target is None or root is None:
                reject('invalid_path', 'Unable to resolve patch target file.')
                continue
            original_text, read_error = _read_text_file_for_mutation(target, max_bytes=max_bytes)
            if read_error or original_text is None:
                reject(_filesystem_reason_code(read_error), read_error or 'Failed to read patch target file.')
                continue

        updated_text, apply_error = _apply_unified_patch_to_text(original_text, file_patch, creating=creating)
        if apply_error or updated_text is None:
            reject('invalid_patch', apply_error or 'Patch could not be applied in memory.')
            continue

        body_bytes = updated_text.encode('utf-8')
        if len(body_bytes) > max_bytes:
            reject('file_too_large', f"Patched content for '{target_relative}' exceeds max_bytes ({len(body_bytes)} > {max_bytes}).")
            continue

        relative = _filesystem_relative_path(root, target)
        entry = dict(preview_entry)
        entry.update({
            'path': relative or target_relative,
            'status': 'would_create' if creating else 'would_modify',
            'size_estimate_bytes': len(body_bytes),
            'would_create_dirs': bool(target is not None and create_dirs and not target.parent.exists()),
        })
        preview_files.append(entry)
        if creating:
            files_to_create.append(entry)
        else:
            files_to_modify.append(entry)
        prepared_writes.append({'root': root, 'target': target, 'updated_text': updated_text, 'summary': entry})

    preview_payload = {
        'mode': mode,
        'root': root_value,
        'files_touched': len(file_patches),
        'files_changed': len(prepared_writes),
        'files': preview_files,
        'files_to_modify': files_to_modify,
        'files_to_create': files_to_create,
        'files_rejected': files_rejected,
        'blocking_reasons': blocking_reasons,
        'allow_create': allow_create,
        'create_dirs': create_dirs,
    }
    if blocking_reasons:
        first_reason = blocking_reasons[0]
        return _tool_payload_json('filesystem', 'apply_patch', 'blocked', reason_code=first_reason.get('reason_code'), message=first_reason.get('message'), **preview_payload)
    if mode == 'preview':
        return _tool_payload_json('filesystem', 'apply_patch', 'preview', review_required=True, **preview_payload)

    applied = []
    for prepared in prepared_writes:
        target = prepared['target']
        summary = dict(prepared['summary'])
        try:
            if summary.get('created') and create_dirs:
                target.parent.mkdir(parents=True, exist_ok=True)
            target.write_text(prepared['updated_text'], encoding='utf-8')
        except Exception as exc:
            message = f"Failed to write patch target '{summary.get('path') or summary.get('new_path') or summary.get('old_path')}': {exc}"
            status = 'partially_applied' if applied else 'failed'
            summary.update({'status': 'failed', 'reason_code': 'write_failed', 'message': message})
            return _tool_payload_json('filesystem', 'apply_patch', status, mode='apply', root=root_value, reason_code='write_failed', message=message, files_changed=len(applied), files=applied + [summary], files_to_modify=files_to_modify, files_to_create=files_to_create, files_rejected=files_rejected, blocking_reasons=[_blocking_reason('write_failed', message, path=summary.get('path'))])
        summary['status'] = 'applied'
        applied.append(summary)

    return _tool_payload_json('filesystem', 'apply_patch', 'applied', mode='apply', root=root_value, files_touched=len(file_patches), files_changed=len(applied), files=applied, files_to_modify=files_to_modify, files_to_create=files_to_create, files_rejected=files_rejected, allow_create=allow_create, create_dirs=create_dirs)



