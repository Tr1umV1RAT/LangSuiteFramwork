def {{ node.id }}_route(state: AgentState) -> str:
    raw_val = state.get("{{ node.params.state_key | default('messages', true) }}", "{}")

    if isinstance(raw_val, list) and raw_val:
        last = raw_val[-1]
        raw_val = last.content if hasattr(last, 'content') else str(last)

    parsed_val = parse_json_safe(raw_val)

    decision = parsed_val.get("{{ node.params.json_field | default('route', true) }}", str(parsed_val)) if isinstance(parsed_val, dict) and "error" not in parsed_val else str(raw_val)
    decision = str(decision).strip().lower()

    {% for route in node.params.routes %}
    if decision == "{{ route.value }}".lower():
        return "{{ route.handle_id }}"
    {% endfor %}

    return "{{ node.params.fallback_handle | default('fallback', true) }}"



{% elif node.type == 'memory_access' %}
def {{ node.id }}_node(state: AgentState, config: RunnableConfig, store: BaseStore) -> dict[str, Any]:
    access_mode = {{ node.params.access_mode | default('profile_read') | tojson }}
    namespace_prefix = {{ node.params.namespace_prefix | default('memory') | tojson }}
    output_key = {{ node.params.output_key | default('memory_payload') | tojson }}
    store_item_key = {{ node.params.store_item_key | default('profile') | tojson }}
    query_key = {{ node.params.query_key | default('messages') | tojson }}
    limit = {{ node.params.limit | default(5) }}

    if access_mode == "profile_read":
        user_id_keys = {{ node.params.user_id_key | default('custom_vars.user_id') | tojson }}.split(".")
        try:
            from functools import reduce
            from operator import getitem
            user_id = str(reduce(getitem, user_id_keys, dict(state)))
        except (KeyError, TypeError):
            user_id = "default_user"
        namespace = (namespace_prefix, user_id)
        item = store.get(namespace, store_item_key)
        value = item.value if item and item.value else None
        memory_meta = _memory_meta_update(state, node_id="{{ node.id }}", memory_system="runtime_memory_access_surface", access_model="runtime_store_profile_get_or_search_projection", durability=GRAPH_STORE_DURABILITY, operation="memory_access_profile_read", output_key=output_key, namespace=namespace, key=store_item_key, value=value, extra={"access_mode": access_mode, "user_id": user_id})
        if value is not None:
            return {output_key: value, "__memory_meta__": memory_meta}
        return {"__memory_meta__": memory_meta}

    if access_mode == "get":
        namespace = (namespace_prefix,)
        item = store.get(namespace, store_item_key)
        value = item.value if item and item.value else None
        memory_meta = _memory_meta_update(state, node_id="{{ node.id }}", memory_system="runtime_memory_access_surface", access_model="runtime_store_profile_get_or_search_projection", durability=GRAPH_STORE_DURABILITY, operation="memory_access_get", output_key=output_key, namespace=namespace, key=store_item_key, value=value, extra={"access_mode": access_mode})
        if value is not None:
            return {output_key: value, "__memory_meta__": memory_meta}
        return {"__memory_meta__": memory_meta}

    query_val = state.get(query_key)
    if isinstance(query_val, list) and query_val:
        last = query_val[-1]
        if hasattr(last, 'content'):
            query_val = last.content
    query_text = str(query_val or "")
    namespace = (namespace_prefix,)
    results = store.search(namespace, query=query_text, limit=limit)
    value = [entry.value for entry in results]
    memory_meta = _memory_meta_update(state, node_id="{{ node.id }}", memory_system="runtime_memory_access_surface", access_model="runtime_store_profile_get_or_search_projection", durability=GRAPH_STORE_DURABILITY, operation="memory_access_search", output_key=output_key, namespace=namespace, value=value, extra={"access_mode": access_mode, "query": query_text, "result_count": len(value)})
    return {output_key: value, "__memory_meta__": memory_meta}


