PROVIDER_ENV_VARS = {{ provider_env_vars | tojson }}
OPENAI_COMPAT_PROVIDER_FAMILIES = set({{ openai_compatible_provider_families | tojson }})


def normalize_provider(provider: str) -> str:
    raw = (provider or "").strip().lower()
    return PROVIDER_ALIASES.get(raw, raw)


def ensure_provider_configuration(provider: str, explicit_env: str | None = None) -> None:
    provider = normalize_provider(provider)
    env_name = (explicit_env or "").strip() or PROVIDER_ENV_VARS.get(provider)
    if not env_name:
        return
    if os.getenv(env_name):
        return
    raise RuntimeError(f"[provider_config_missing] Provider '{provider}' requires environment variable '{env_name}' for runtime execution")


def build_chat_model(*, provider: str, model_name: str, temperature: float, explicit_env: str | None = None, api_base_url: str | None = None, max_tokens: int | None = None, top_p: float | None = None, frequency_penalty: float | None = None, presence_penalty: float | None = None, stop_sequences: list[str] | None = None):
    provider = normalize_provider(provider)
    api_base_url = (api_base_url or "").strip() or None
    if provider in OPENAI_COMPAT_PROVIDER_FAMILIES:
        if not api_base_url:
            raise RuntimeError(f"[provider_config_missing] Provider '{provider}' requires api_base_url for runtime execution")
        try:
            from langchain_openai import ChatOpenAI
            api_key = (os.getenv((explicit_env or "").strip()) if (explicit_env or "").strip() else None) or os.getenv("OPENAI_API_KEY") or "not-needed"
            kwargs = {
                "model": model_name,
                "temperature": temperature,
                "base_url": api_base_url,
                "api_key": api_key,
            }
            if max_tokens is not None:
                kwargs["max_tokens"] = max_tokens
            if top_p is not None:
                kwargs["top_p"] = top_p
            if frequency_penalty is not None:
                kwargs["frequency_penalty"] = frequency_penalty
            if presence_penalty is not None:
                kwargs["presence_penalty"] = presence_penalty
            if stop_sequences:
                kwargs["stop"] = stop_sequences
            return ChatOpenAI(**kwargs)
        except Exception as exc:
            raise RuntimeError(f"[provider_init_failed] Unable to initialize OpenAI-compatible provider '{provider}' for model '{model_name}': {exc}") from exc
    ensure_provider_configuration(provider, explicit_env)
    try:
        llm = init_chat_model(model=model_name, model_provider=provider, temperature=temperature)
        extra_kwargs = {}
        if max_tokens is not None:
            extra_kwargs["max_tokens"] = max_tokens
        if top_p is not None:
            extra_kwargs["top_p"] = top_p
        if frequency_penalty is not None:
            extra_kwargs["frequency_penalty"] = frequency_penalty
        if presence_penalty is not None:
            extra_kwargs["presence_penalty"] = presence_penalty
        if stop_sequences:
            extra_kwargs["stop"] = stop_sequences
        if extra_kwargs and hasattr(llm, "bind"):
            llm = llm.bind(**extra_kwargs)
        return llm
    except Exception as exc:
        raise RuntimeError(f"[provider_init_failed] Unable to initialize provider '{provider}' for model '{model_name}': {exc}") from exc

GRAPH_STORE_BACKEND = {{ runtime_settings.storeBackend | tojson }}
GRAPH_STORE_PATH = {{ runtime_settings.storePath | tojson }}
GRAPH_STORE_DURABILITY = {{ ('store_runtime_sqlite_local_user_configurable' if runtime_settings.storeBackend == 'sqlite_local' else 'store_runtime_inmemory_user_configurable') | tojson }}


def parse_json_safe(content):
    if isinstance(content, dict):
        return content
    if isinstance(content, str):
        try:
            return json.loads(content)
        except (json.JSONDecodeError, ValueError):
            return {"error": "Invalid JSON", "raw": content}
    return {"error": "Unexpected type", "raw": str(content)}



def _normalize_runtime_context(runtime: Runtime | None) -> dict[str, Any]:
    if runtime is None:
        return {}
    raw = getattr(runtime, "context", None)
    if raw is None:
        return {}
    if isinstance(raw, dict):
        return dict(raw)
    if hasattr(raw, "model_dump"):
        try:
            dumped = raw.model_dump()
            if isinstance(dumped, dict):
                return dumped
        except Exception:
            pass
    if hasattr(raw, "__dict__"):
        return {k: v for k, v in vars(raw).items() if not k.startswith('_')}
    return {}


def _structured_source(state: AgentState, source_key: str) -> Any:
    if source_key in state:
        return state.get(source_key)
    custom_vars = state.get("custom_vars") or {}
    if isinstance(custom_vars, dict) and source_key in custom_vars:
        return custom_vars.get(source_key)
    return None


def _preview_memory_value(value: Any) -> Any:
    if isinstance(value, list):
        return {
            "kind": "list",
            "count": len(value),
            "sample": [str(item)[:140] for item in value[:2]],
        }
    if isinstance(value, dict):
        preview = {str(k): str(v)[:140] for k, v in list(value.items())[:3]}
        return {
            "kind": "dict",
            "keys": list(value.keys())[:5],
            "sample": preview,
        }
    if value is None:
        return None
    text = str(value)
    return text[:180] + ("…" if len(text) > 180 else "")


def _memory_meta_update(state: AgentState, *, node_id: str, memory_system: str, durability: str, operation: str, output_key: str | None = None, state_key: str | None = None, namespace: Any = None, key: Any = None, value: Any = None, access_model: str | None = None, extra: dict[str, Any] | None = None) -> dict[str, Any]:
    import time

    current = state.get("__memory_meta__")
    if not isinstance(current, dict):
        current = {}
    entry = {
        "node_id": node_id,
        "memory_system": memory_system,
        "durability": durability,
        "operation": operation,
        "updated_at": time.time(),
        "output_key": output_key,
        "state_key": state_key,
        "namespace": list(namespace) if isinstance(namespace, tuple) else namespace,
        "key": key,
        "last_entry": _preview_memory_value(value),
        "store_backend": GRAPH_STORE_BACKEND,
        "store_path": GRAPH_STORE_PATH if GRAPH_STORE_BACKEND == "sqlite_local" else None,
        "access_model": access_model,
    }
    if extra:
        entry.update(extra)
    next_meta = dict(current)
    next_meta[node_id] = entry
    return next_meta


