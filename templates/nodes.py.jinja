{% elif node.type == 'context_trimmer' %}
def {{ node.id }}_node(state: AgentState) -> dict[str, Any]:
    from langchain_core.messages import RemoveMessage, SystemMessage
    
    max_msgs = {{ node.params.max_messages | default(10) }}
    messages = state.get("messages", [])
    
    if len(messages) <= max_msgs:
        return {"__memory_meta__": _memory_meta_update(state, node_id="{{ node.id }}", memory_system="context_window_trim", durability="ephemeral_thread_state", operation="trim_noop", access_model="thread_state_message_trimming", output_key="messages", value={"kept": len(messages), "trimmed": 0, "max_messages": max_msgs})}
        
    has_system = isinstance(messages[0], SystemMessage)
    start_idx = 1 if has_system else 0
    end_idx = len(messages) - max_msgs
    
    if end_idx > start_idx:
        to_remove = messages[start_idx:end_idx]
        return {
            "messages": [RemoveMessage(id=m.id) for m in to_remove if m.id],
            "__memory_meta__": _memory_meta_update(state, node_id="{{ node.id }}", memory_system="context_window_trim", durability="ephemeral_thread_state", operation="trim_messages", access_model="thread_state_message_trimming", output_key="messages", value={"kept": max_msgs, "trimmed": len(to_remove), "max_messages": max_msgs}),
        }
        
    return {"__memory_meta__": _memory_meta_update(state, node_id="{{ node.id }}", memory_system="context_window_trim", durability="ephemeral_thread_state", operation="trim_noop", access_model="thread_state_message_trimming", output_key="messages", value={"kept": len(messages), "trimmed": 0, "max_messages": max_msgs})}


