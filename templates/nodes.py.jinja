{% elif node.type == 'reduce_join' %}
def {{ node.id }}_node(state: AgentState) -> dict[str, Any]:
    source_key = {{ node.params.results_key | default('fanout_results') | tojson }}
    output_key = {{ node.params.output_key | default('fanout_joined') | tojson }}
    join_mode = {{ node.params.join_mode | default('list') | tojson }}
    item_field = {{ node.params.item_field | default('') | tojson }}
    separator = {{ node.params.separator | default('\n\n') | tojson }}
    values = state.get(source_key)
    if values is None:
        values = (state.get("custom_vars") or {}).get(source_key)
    if values is None:
        values = []
    if not isinstance(values, list):
        values = [values]

    extracted: list[Any] = []
    for item in values:
        current = item
        if item_field:
            if isinstance(current, dict):
                current = current.get(item_field)
            else:
                current = getattr(current, item_field, None)
        extracted.append(current)

    if join_mode == "count":
        reduced_value: Any = len([item for item in extracted if item is not None])
    elif join_mode == "first_non_null":
        reduced_value = next((item for item in extracted if item is not None), None)
    elif join_mode == "text_join":
        reduced_value = separator.join(str(item) for item in extracted if item is not None)
    else:
        reduced_value = extracted

    result: dict[str, Any] = {output_key: reduced_value}
    {% if node.params.progress_key %}
    result[{{ node.params.progress_key | tojson }}] = {
        "source_key": source_key,
        "items_seen": len(values),
        "join_mode": join_mode,
        "output_key": output_key,
    }
    {% endif %}
    return result


