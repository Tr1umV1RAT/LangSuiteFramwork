    {% if prop.reducer == 'add_messages' %}
    {{ prop.name }}: Annotated[list[AnyMessage], add_messages]
    {% elif prop.reducer == 'operator.add' %}
    {{ prop.name }}: Annotated[list[Any], operator.add]
    {% elif prop.reducer == 'update' %}
    {{ prop.name }}: Annotated[dict[str, Any], update_dict]
    {% elif prop.reducer == 'none' %}
    {{ prop.name }}: Optional[{{ prop.type | default('Any') }}]
    {% else %}
    {{ prop.name }}: {{ prop.type | default('Any') }}
    {% endif %}
    {% endfor %}
    {% endif %}
